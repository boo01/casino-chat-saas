# Casino Chat SaaS - Environment Variables
# Copy this file to .env.local (development) or .env (production) and fill in actual values
# NEVER commit actual secrets to version control

# ==================== Application ====================

NODE_ENV=development
APP_NAME=casino-chat
APP_VERSION=1.0.0

# ==================== Server Configuration ====================

# API Server
API_HOST=0.0.0.0
API_PORT=3000
API_WORKERS_COUNT=4

# WebSocket Server
WS_HOST=0.0.0.0
WS_PORT=3001
WS_WORKERS_COUNT=4

# ==================== Database ====================

# PostgreSQL Connection
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://casino_chat:change_me@localhost:5432/casino_chat_dev
DATABASE_POOL_MIN=5
DATABASE_POOL_MAX=25
DATABASE_POOL_TIMEOUT=5000
DATABASE_STATEMENT_TIMEOUT=30000
DATABASE_IDLE_TIMEOUT=600000

# Connection pooler (PgBouncer)
PGBOUNCER_HOST=localhost
PGBOUNCER_PORT=6432

# ==================== Redis ====================

# Redis Connection
REDIS_URL=redis://localhost:6379

# Redis Cluster (optional, for production)
REDIS_CLUSTER_NODES=
REDIS_CLUSTER_OPTIONS=
REDIS_POOL_SIZE=50
REDIS_SOCKET_TIMEOUT=5000

# Redis Keyspace
REDIS_KEY_PREFIX=casino-chat

# ==================== Security & Secrets ====================

# JWT Configuration
JWT_SECRET=CHANGE_ME_GENERATE_SECURE_SECRET_MIN_32_CHARS
JWT_EXPIRY_SECONDS=3600
JWT_REFRESH_SECRET=CHANGE_ME_GENERATE_SECURE_SECRET_MIN_32_CHARS
JWT_REFRESH_EXPIRY_SECONDS=604800

# API Signing (HMAC)
API_SIGNING_SECRET=CHANGE_ME_GENERATE_SECURE_SECRET_MIN_32_CHARS
API_SIGNATURE_WINDOW=300

# Admin Session
ADMIN_SESSION_SECRET=CHANGE_ME_GENERATE_SECURE_SECRET_MIN_32_CHARS
ADMIN_SESSION_TIMEOUT_MINUTES=30

# ==================== CORS & Network ====================

CORS_ORIGIN=http://localhost:3000,http://localhost:3001,http://localhost:3002
CORS_CREDENTIALS=true
CORS_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_HEADERS=Content-Type,Authorization,X-Signature,X-Timestamp,X-Casino-ID

# Rate Limiting (requests/messages per minute)
RATE_LIMIT_MESSAGES_PER_MINUTE=10
RATE_LIMIT_API_REQUESTS_PER_MINUTE=100
RATE_LIMIT_ADMIN_REQUESTS_PER_MINUTE=200

# ==================== TLS/SSL ====================

TLS_ENABLED=false
TLS_CERT_PATH=
TLS_KEY_PATH=

# ==================== Logging ====================

LOG_LEVEL=debug
LOG_FORMAT=json
LOG_FILE_ENABLED=false
LOG_FILE_PATH=./logs
LOG_FILE_ROTATION=daily
LOG_RETENTION_DAYS=30

# Sentry (Error tracking)
SENTRY_DSN=
SENTRY_ENABLED=false
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# ==================== Features & Configuration ====================

# Feature Flags
FEATURE_GLOBAL_CHAT=true
FEATURE_CHANNEL_SYSTEM=true
FEATURE_WAGER_GATE=true
FEATURE_MODERATION=true
FEATURE_REPLY_THREAD=false
FEATURE_WIN_CARDS=false
FEATURE_REACTIONS=false
FEATURE_GIF_EMOJI=false
FEATURE_PLAYER_PROFILES=true
FEATURE_WIN_RESHARE=false
FEATURE_PLAYER_LEVELS=false
FEATURE_RAIN_EVENTS=false
FEATURE_PROMO_CARDS=false
FEATURE_LEADERBOARD=false
FEATURE_TRIVIA=false
FEATURE_TIPPING=false
FEATURE_PREMIUM_CHAT=false
FEATURE_STREAMER_MODE=false

# Message Configuration
MESSAGE_MAX_LENGTH=5000
MESSAGE_RETENTION_DAYS=90
AUTO_DELETE_MESSAGES_AFTER_DAYS=90
MESSAGE_BUFFER_MAX_SIZE=100

# Moderation
MODERATION_MODE=moderate
AUTOMOD_WORD_FILTER_ENABLED=true
MODERATION_ACTION_BUFFER_SIZE=1000

# Rain Events
RAIN_DEFAULT_DURATION_SECONDS=60
RAIN_DEFAULT_CLAIM_WINDOW_SECONDS=120

# WebSocket
WS_HEARTBEAT_INTERVAL_MS=30000
WS_HEARTBEAT_TIMEOUT_MS=5000
WS_MAX_PAYLOAD_SIZE=100000
WS_RECONNECT_DELAY_MS=1000
WS_MAX_RECONNECT_ATTEMPTS=5

# ==================== Analytics ====================

ANALYTICS_ENABLED=true
ANALYTICS_BATCH_SIZE=1000
ANALYTICS_FLUSH_INTERVAL_MS=30000
ANALYTICS_RETENTION_DAYS=365

# ==================== Backup & Storage ====================

# AWS S3 for backups
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=casino-chat-backups

# Backup Schedule (cron format)
BACKUP_ENABLED=false
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30

# ==================== External Services ====================

# Email Service
EMAIL_ENABLED=false
EMAIL_PROVIDER=sendgrid
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@casino-chat.io

# SMS Service (optional)
SMS_ENABLED=false
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ==================== Monitoring & Observability ====================

# Prometheus Metrics
PROMETHEUS_ENABLED=false
PROMETHEUS_PORT=9090

# Uptime Kuma
UPTIME_KUMA_URL=
UPTIME_KUMA_API_KEY=

# ELK Stack / Log Aggregation
ELK_ENABLED=false
ELASTICSEARCH_URL=
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=

# DataDog
DATADOG_ENABLED=false
DATADOG_API_KEY=
DATADOG_APP_KEY=

# ==================== Development ====================

# Enable debug logging for specific modules
DEBUG=casino-chat:*

# Hot reload
HOT_RELOAD=true

# Test Database (used by integration tests)
TEST_DATABASE_URL=postgresql://casino_chat:change_me@localhost:5432/casino_chat_test

# ==================== Production ====================

# Enable only for production
PRODUCTION_MODE=false
ENABLE_RATE_LIMITING=true
ENABLE_REQUEST_LOGGING=true
ENABLE_PERFORMANCE_MONITORING=true

# Custom configuration
CUSTOM_CONFIG_PATH=
CUSTOM_CONFIG_ENABLED=false
