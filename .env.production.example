# Application
NODE_ENV=production
LOG_LEVEL=info
PORT=3000

# Database (use SSL in production)
DATABASE_URL=postgresql://user:password@db-host:5432/casino_chat?sslmode=require

# Redis (with password)
REDIS_URL=redis://:password@redis-host:6379

# JWT (MUST be unique and strong)
JWT_SECRET=generate-a-strong-random-string-here-min-32-chars
JWT_EXPIRATION=24h

# Swagger (disable in production)
SWAGGER_ENABLED=false

# CORS (restrict to your domain)
CORS_ORIGIN=https://your-casino-domain.com

# Webhooks
WEBHOOK_TIMEOUT_MS=5000

# Admin Panel
ADMIN_API_KEY_HEADER=X-Api-Key
ADMIN_TIMESTAMP_HEADER=X-Timestamp
ADMIN_SIGNATURE_HEADER=X-Signature

# Socket.io
SOCKET_CORS_ORIGIN=https://your-casino-domain.com
SOCKET_TRANSPORTS=websocket,polling
