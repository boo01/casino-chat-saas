# Application
NODE_ENV=development
LOG_LEVEL=debug
PORT=3000

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/casino_chat_saas

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRATION=24h

# Swagger
SWAGGER_ENABLED=true
SWAGGER_PATH=/api/docs

# CORS
CORS_ORIGIN=http://localhost:3001

# Webhooks
WEBHOOK_TIMEOUT_MS=5000

# Admin Panel
ADMIN_API_KEY_HEADER=X-Api-Key
ADMIN_TIMESTAMP_HEADER=X-Timestamp
ADMIN_SIGNATURE_HEADER=X-Signature

# Socket.io
SOCKET_CORS_ORIGIN=http://localhost:3001
SOCKET_TRANSPORTS=websocket,polling

# Bull Queue
BULL_DEFAULT_REPEAT_PATTERN=0 0 * * *
